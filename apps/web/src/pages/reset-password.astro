---
import AppShellLayout from "../layouts/AppShellLayout.astro";
import AuthShell from "../features/auth/components/AuthShell.astro";
import { t } from "@/lib/i18n";
import { resolveServerLocale } from "@/lib/locale";

const token = Astro.url.searchParams.get("token") || "";
const locale = resolveServerLocale(Astro.request);
const m = t(locale);
---

<AppShellLayout title={m.common.resetPassword} locale={locale} renderFooter={false}>
  {token ? (
    <AuthShell
      title={m.auth.resetTitle}
      description={m.auth.resetDescription}
      actionLabel={m.auth.resetAction}
      locale={locale}
      endpoint="/api/v1/auth/reset-password"
      extraFields={[
        { name: "token", label: "token", value: token, type: "text", hidden: true },
        { name: "new_password", label: m.auth.newPassword, type: "password", placeholder: "••••••••" },
      ]}
      requiresPassword={false}
      successRedirect="/sign-in"
      links={[
        { href: "/sign-in", label: m.common.backToSignIn },
      ]}
    />
  ) : (
    <div class="mx-auto w-full max-w-lg rounded-lg border border-border bg-card p-8 text-card-foreground">
      <p class="text-xs font-medium uppercase tracking-[0.16em] text-muted-foreground">{m.common.resetPassword}</p>
      <h1 class="mt-3 text-2xl font-semibold text-foreground">{m.auth.resetLinkRequiredTitle}</h1>
      <p class="mt-3 text-sm leading-7 text-muted-foreground">
        {m.auth.resetLinkRequiredDescription}
      </p>
      <div class="mt-6 flex flex-wrap gap-3">
        <a class="inline-flex h-10 items-center rounded-md bg-primary px-4 text-sm font-medium text-primary-foreground" href="/forgot-password">
          {m.auth.sendResetInstructions}
        </a>
        <a class="inline-flex h-10 items-center rounded-md border border-input bg-background px-4 text-sm font-medium text-foreground transition hover:bg-accent hover:text-accent-foreground" href="/sign-in">
          {m.common.backToSignIn}
        </a>
      </div>
    </div>
  )}
</AppShellLayout>
