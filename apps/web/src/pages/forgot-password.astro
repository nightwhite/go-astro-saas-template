---
import AppShellLayout from "../layouts/AppShellLayout.astro";
import AuthShell from "../features/auth/components/AuthShell.astro";
import { t } from "@/lib/i18n";
import { resolveServerLocale } from "@/lib/locale";

const locale = resolveServerLocale(Astro.request);
const m = t(locale);
---

<AppShellLayout title={m.common.forgotPassword} locale={locale} renderFooter={false}>
  <AuthShell
    title={m.auth.forgotTitle}
    description={m.auth.forgotDescription}
    actionLabel={m.auth.forgotAction}
    locale={locale}
    endpoint="/api/v1/auth/forgot-password"
    requiresPassword={false}
    successRedirect=""
    successMessage={m.auth.forgotSuccess}
    labels={{ forgotDevResetLinkPrefix: m.auth.forgotDevResetLinkPrefix }}
    links={[
      { href: "/sign-in", label: m.common.backToSignIn },
    ]}
  />
</AppShellLayout>
