---
import AppShellLayout from "../../layouts/AppShellLayout.astro";
import { fetchPublishedPostBySlug, renderBlogMarkdown, selectTranslation } from "@/lib/blog";
import { resolveServerLocale } from "@/lib/locale";
import { t } from "@/lib/i18n";

export const prerender = false;

const locale = resolveServerLocale(Astro.request);
const m = t(locale);
const slug = String(Astro.params.slug ?? "").trim();
const post = await fetchPublishedPostBySlug(slug);

if (!post) {
  return new Response("Not Found", { status: 404 });
}

const translation = selectTranslation(post, locale);
if (!translation) {
  return new Response("Not Found", { status: 404 });
}
const html = renderBlogMarkdown(translation.content);
---

<AppShellLayout title={translation.meta_title || translation.title} locale={locale}>
  <div class="mx-auto max-w-3xl px-6 py-12">
    <a class="text-sm text-muted-foreground underline underline-offset-4 hover:text-foreground" href="/blog">
      {m.blog.backToBlog}
    </a>

    <article class="mt-8">
      <h1 class="text-3xl font-bold tracking-tight">{translation.title}</h1>
      {translation.excerpt ? <p class="mt-3 text-lg text-muted-foreground">{translation.excerpt}</p> : null}

      <div class="mt-4 text-sm text-muted-foreground">
        <span>{m.blog.by}{post.author_name || "Admin"}</span>
        {post.published_at ? (
          <span class="ml-2">· {new Date(post.published_at).toLocaleDateString(locale, { year: "numeric", month: "long", day: "numeric" })}</span>
        ) : null}
      </div>

      <div class="prose mt-10 max-w-none dark:prose-invert">
        <div set:html={html} />
      </div>
    </article>
  </div>
</AppShellLayout>
