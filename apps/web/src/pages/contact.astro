---
import AppShellLayout from "../layouts/AppShellLayout.astro";
import { t } from "@/lib/i18n";
import { resolveServerLocale } from "@/lib/locale";

const locale = resolveServerLocale(Astro.request);
const m = t(locale);
const contact = m.marketing.contact;
const supportEmail = "support@example.com";
---

<AppShellLayout title={contact.title} locale={locale}>
  <div class="page-shell py-12">
    <div class="mx-auto max-w-3xl rounded-xl border border-border bg-card p-6 text-card-foreground shadow-sm md:p-8">
      <h1 class="text-3xl font-bold tracking-tight text-foreground">{contact.heading}</h1>
      <p class="mt-4 text-base leading-relaxed text-muted-foreground">{contact.lead}</p>

      <div class="mt-8 rounded-lg border border-border bg-background p-5">
        <div class="text-sm font-semibold text-foreground">{contact.emailLabel}</div>
        <a
          class="mt-2 inline-block text-sm text-foreground underline underline-offset-4 transition hover:text-primary"
          href={`mailto:${supportEmail}`}
        >
          {supportEmail}
        </a>
        <p class="mt-3 text-sm text-muted-foreground">{contact.replySoon}</p>
      </div>

      <div class="mt-8">
        <a
          class="inline-flex h-10 items-center justify-center rounded-md border border-input bg-background px-4 text-sm font-medium text-foreground transition hover:bg-accent hover:text-accent-foreground"
          href="/"
        >
          {contact.ctaHome}
        </a>
      </div>
    </div>
  </div>
</AppShellLayout>
