---
import AppShellLayout from "../../layouts/AppShellLayout.astro";
import { fetchPreviewPost, renderBlogMarkdown, resolvePostLocale, selectTranslation } from "@/lib/blog";
import { t } from "@/lib/i18n";

export const prerender = false;

const token = Astro.url.searchParams.get("token") ?? "";
const lang = Astro.url.searchParams.get("lang");

if (!token) {
  return new Response("Missing token", { status: 400 });
}

const data = await fetchPreviewPost(token);
if (!data) {
  return new Response("Not Found", { status: 404 });
}
const post = data.post;
const resolvedLocale = resolvePostLocale(lang || data.preview.language);
const m = t(resolvedLocale);
const translation = selectTranslation(post, resolvedLocale);
if (!translation) {
  return new Response("Not Found", { status: 404 });
}

const html = renderBlogMarkdown(translation.content);
---

<AppShellLayout title={`[Preview] ${translation.meta_title || translation.title}`} locale={resolvedLocale} noindex>
  <div class="mx-auto max-w-3xl px-6 py-12">
    <div class="rounded-xl border border-amber-200/70 bg-amber-50 p-4 text-sm text-amber-900 dark:border-amber-900/50 dark:bg-amber-950/20 dark:text-amber-200">
      <div class="font-semibold">{m.blog.previewModeTitle}</div>
      <div class="mt-1">{post.status === "published" ? m.blog.previewModeBodyPublished : m.blog.previewModeBodyUnpublished}</div>
    </div>

    <div class="mt-6">
      <a
        class="text-sm text-muted-foreground underline underline-offset-4 hover:text-foreground"
        href="/blog"
      >
        {m.blog.backToBlog}
      </a>
    </div>

    <article class="mt-8">
      <h1 class="text-3xl font-bold tracking-tight">{translation.title}</h1>
      {translation.excerpt ? <p class="mt-3 text-lg text-muted-foreground">{translation.excerpt}</p> : null}
      <div class="mt-4 text-sm text-muted-foreground">
        <span>{m.blog.by}{post.author_name || "Admin"}</span>
        <span class="ml-2">· {new Date().toLocaleDateString(resolvedLocale, { year: "numeric", month: "long", day: "numeric" })}</span>
      </div>
      <div class="prose mt-10 max-w-none dark:prose-invert">
        {translation.content ? <div set:html={html} /> : <div class="text-muted-foreground">{m.blog.contentNotFound}</div>}
      </div>
    </article>
  </div>
</AppShellLayout>
