---
import AppShellLayout from "../layouts/AppShellLayout.astro";
import { t } from "@/lib/i18n";
import { resolveServerLocale } from "@/lib/locale";

const locale = resolveServerLocale(Astro.request);
const m = t(locale);
const about = m.marketing.about;
---

<AppShellLayout title={about.title} locale={locale}>
  <div class="page-shell py-12">
    <div class="mx-auto max-w-3xl rounded-xl border border-border bg-card p-6 text-card-foreground shadow-sm md:p-8">
      <h1 class="text-3xl font-bold tracking-tight text-foreground">{about.heading}</h1>
      <p class="mt-4 text-base leading-relaxed text-muted-foreground">{about.lead}</p>

      <div class="mt-8 rounded-lg border border-border bg-muted/40 p-5 text-sm text-muted-foreground">
        <div class="font-semibold text-foreground">{about.tipTitle}</div>
        <ul class="mt-3 list-disc space-y-2 pl-5">
          {about.tips.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </div>

      <div class="mt-8 flex flex-wrap gap-3">
        <a
          class="inline-flex h-10 items-center justify-center rounded-md border border-input bg-background px-4 text-sm font-medium text-foreground transition hover:bg-accent hover:text-accent-foreground"
          href="/"
        >
          {about.ctaHome}
        </a>
        <a
          class="inline-flex h-10 items-center justify-center rounded-md bg-primary px-4 text-sm font-medium text-primary-foreground shadow-sm transition hover:opacity-90"
          href="/sign-in"
        >
          {about.ctaSignIn}
        </a>
      </div>
    </div>
  </div>
</AppShellLayout>
