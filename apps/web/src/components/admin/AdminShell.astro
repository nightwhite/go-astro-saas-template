---
import AppShellLayout from "@/layouts/AppShellLayout.astro";
import AdminRouterApp from "@/components/admin/AdminRouterApp";
import { resolveServerLocale } from "@/lib/locale";
import { t } from "@/lib/i18n";

const locale = resolveServerLocale(Astro.request);
const m = t(locale);
---

<AppShellLayout title={m.common.admin} noindex fullBleed={true} renderNav={false} renderFooter={false} locale={locale}>
  <AdminRouterApp client:load locale={locale} initialPath={Astro.url.pathname} initialSearch={Astro.url.search} />
</AppShellLayout>
