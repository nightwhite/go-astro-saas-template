---
import { SITE_NAME } from "@/constants";
import { t } from "@/lib/i18n";
import { resolveServerLocale } from "@/lib/locale";

const locale = resolveServerLocale(Astro.request);
const m = t(locale);
---

<footer class="border-t border-border bg-background">
  <div class="mx-auto max-w-7xl px-4 py-10 md:px-6">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
      <div class="text-sm text-muted-foreground">
        © {new Date().getFullYear()} {SITE_NAME}. {m.footer.rightsReserved}
      </div>
      <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-sm">
        <a class="text-muted-foreground underline-offset-4 hover:underline hover:text-foreground" href="/terms">
          {m.footer.terms}
        </a>
        <a class="text-muted-foreground underline-offset-4 hover:underline hover:text-foreground" href="/privacy">
          {m.footer.privacy}
        </a>
        <a
          class="text-muted-foreground underline-offset-4 hover:underline hover:text-foreground"
          href="https://github.com/LubomirGeorgiev/cloudflare-workers-nextjs-saas-template"
          target="_blank"
          rel="noreferrer"
        >
          GitHub
        </a>
        <a class="text-muted-foreground underline-offset-4 hover:underline hover:text-foreground" href="/admin">
          {m.footer.admin}
        </a>
      </div>
    </div>
  </div>
</footer>
