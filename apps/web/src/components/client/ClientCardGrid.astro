---
import { clientHomeCards } from "@/features/client/home";
---

<div class="grid gap-4 md:grid-cols-3">
  {clientHomeCards.map((card) => (
    <article class="rounded-lg border border-border bg-card p-5">
      <p class="text-lg font-semibold text-card-foreground">{card.title}</p>
      <p class="mt-3 text-sm leading-6 text-muted-foreground">{card.description}</p>
    </article>
  ))}
</div>
