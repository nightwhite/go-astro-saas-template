---
import AppShellLayout from "@/layouts/AppShellLayout.astro";
import DashboardApp from "@/components/dashboard/DashboardApp";
import { resolveServerLocale } from "@/lib/locale";
import { t } from "@/lib/i18n";

const locale = resolveServerLocale(Astro.request);
const m = t(locale);
---

<AppShellLayout title={m.common.dashboard} noindex fullBleed={true} renderNav={false} renderFooter={false} locale={locale}>
  <DashboardApp client:load locale={locale} initialPath={Astro.url.pathname} initialSearch={Astro.url.search} />
</AppShellLayout>
