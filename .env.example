# Application runtime mode (development, staging, production).
APP_ENV=development
# Human-readable application name used in logs and metadata.
APP_NAME=go-astro-template
# Host interface for the API server bind address.
APP_HOST=0.0.0.0
# API server listen port.
APP_PORT=8080
# Maximum duration to read an incoming HTTP request.
APP_READ_TIMEOUT=10s
# Maximum duration to write an HTTP response.
APP_WRITE_TIMEOUT=15s
# Maximum keep-alive idle time for HTTP connections.
APP_IDLE_TIMEOUT=60s
# Graceful shutdown timeout before forcing server stop.
APP_SHUTDOWN_TIMEOUT=10s
# Public web origin used for CORS and cookie/security checks.
APP_WEB_ORIGIN=http://localhost:4321
# Public API base URL used in links and callbacks.
APP_BASE_URL=http://localhost:8080

# PostgreSQL DSN for the primary application database connection.
POSTGRES_DSN=postgres://postgres:postgres@localhost:5432/go_astro_template?sslmode=disable
# Maximum number of open PostgreSQL connections.
POSTGRES_MAX_OPEN_CONNS=30
# Maximum number of idle PostgreSQL connections.
POSTGRES_MAX_IDLE_CONNS=15
# Maximum lifetime for each PostgreSQL connection.
POSTGRES_CONN_MAX_LIFETIME=30m

# Redis host:port for cache, sessions, rate limiting, and queues.
REDIS_ADDR=localhost:6379
# Redis password (leave empty when Redis auth is disabled).
REDIS_PASSWORD=
# Redis logical database index.
REDIS_DB=0

# Enable CSRF protection for state-changing requests.
SECURITY_CSRF_ENABLED=true
# Enable API metrics endpoint and metric collection.
SECURITY_METRICS_ENABLED=true
# HTTP header name used to pass CSRF token from client.
SECURITY_CSRF_HEADER=X-CSRF-Token
# Cookie name used to store CSRF token state.
SECURITY_CSRF_COOKIE_NAME=go_astro_csrf
# CSRF token time-to-live.
SECURITY_CSRF_TTL=2h
# Secret key used to sign CSRF tokens.
SECURITY_CSRF_SECRET=

# SMTP server host for outgoing email.
SMTP_HOST=localhost
# SMTP server port.
SMTP_PORT=1025
# SMTP username for authentication (optional).
SMTP_USERNAME=
# SMTP password for authentication (optional).
SMTP_PASSWORD=
# Default sender email address.
SMTP_FROM=noreply@example.com

# R2 account identifier for object storage.
R2_ACCOUNT_ID=local
# R2 access key ID.
R2_ACCESS_KEY_ID=local
# R2 secret access key.
R2_SECRET_ACCESS_KEY=local
# R2 bucket name for uploaded files.
R2_BUCKET=app-assets
# R2 endpoint URL.
R2_ENDPOINT=http://localhost:9000
# Public base URL used to serve storage objects.
R2_PUBLIC_BASE_URL=http://localhost:9000/app-assets

# Enable captcha checks for login/register/reset flows.
SECURITY_CAPTCHA_ENABLED=false
# Enforce strict captcha behavior when enabled.
SECURITY_CAPTCHA_STRICT=false
# Maximum accepted HTTP request body size in bytes.
SECURITY_MAX_BODY_BYTES=1048576
# Time window for login rate limiting.
SECURITY_LOGIN_RATE_LIMIT_WINDOW=1m
# Maximum login attempts allowed per rate limit window.
SECURITY_LOGIN_RATE_LIMIT_MAX=10
# Time window for admin API rate limiting.
SECURITY_ADMIN_RATE_LIMIT_WINDOW=1m
# Maximum admin requests allowed per rate limit window.
SECURITY_ADMIN_RATE_LIMIT_MAX=120
# Time window for password reset rate limiting.
SECURITY_RESET_RATE_LIMIT_WINDOW=5m
# Maximum password reset requests allowed per window.
SECURITY_RESET_RATE_LIMIT_MAX=5
# Time-to-live for idempotency keys.
SECURITY_IDEMPOTENCY_TTL=24h
# Enable pprof profiling endpoints.
SECURITY_ENABLE_PPROF=false

# Prefix for background job queue keys/namespaces.
JOBS_QUEUE_PREFIX=go_astro_template
# Default queue name for normal-priority jobs.
JOBS_DEFAULT_QUEUE=default
# Queue name for high-priority/critical jobs.
JOBS_CRITICAL_QUEUE=critical
# Worker polling interval for pulling queued jobs.
JOBS_POLL_INTERVAL=2s
# Interval for scheduler tick (recurring jobs/maintenance).
JOBS_SCHEDULE_INTERVAL=5m
# Maximum retry attempts for failed jobs.
JOBS_MAX_RETRIES=5
# Base backoff duration used for retry delay calculation.
JOBS_BACKOFF_BASE=5s
# Retention time for finished job records.
JOBS_RETENTION=168h

# Cache TTL for settings/config snapshots in seconds.
SETTINGS_CACHE_TTL_SECONDS=300
